# Evitar cache do HTML para sempre servir a página atualizada (incl. mobile)
<IfModule mod_headers.c>
  # Todas as páginas HTML
  <FilesMatch "\.(html|htm)$">
    Header always set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
    Header always set Vary "*"
  </FilesMatch>
  # index.html explicitamente (quando acessam / ou index.html)
  <Files "index.html">
    Header always set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
    Header always set Vary "*"
  </Files>
</IfModule>
# Forçar recarga quando acessam a raiz do site (evita cache no mobile)
<IfModule mod_setenvif.c>
  SetEnvIf Request_URI "^/?$" NO_CACHE
</IfModule>
<IfModule mod_headers.c>
  Header always set Cache-Control "no-cache, no-store, must-revalidate, max-age=0" env=NO_CACHE
  Header always set Pragma "no-cache" env=NO_CACHE
  Header always set Expires "0" env=NO_CACHE
</IfModule>

# Desabilitar cache para imagens: sempre baixar a versão mais recente em cada acesso
<IfModule mod_expires.c>
  ExpiresActive On

  # Imagens – sem cache
  ExpiresByType image/png    "access plus 0 seconds"
  ExpiresByType image/webp   "access plus 0 seconds"
  ExpiresByType image/jpeg   "access plus 0 seconds"
  ExpiresByType image/jpg    "access plus 0 seconds"
  ExpiresByType image/gif    "access plus 0 seconds"
  ExpiresByType image/svg+xml "access plus 0 seconds"
  ExpiresByType image/x-icon "access plus 0 seconds"
  ExpiresByType image/avif   "access plus 0 seconds"

  # Fontes (se servir localmente no futuro) – mantive 1 ano
  ExpiresByType font/woff2   "access plus 1 year"
  ExpiresByType font/woff    "access plus 1 year"

  # CSS e JS estáticos (se usar arquivos .css/.js externos) – mantive 1 mês
  ExpiresByType text/css     "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Cache-Control das imagens também configurado para não cachear
<IfModule mod_headers.c>
  <FilesMatch "\.(png|webp|jpe?g|gif|svg|ico|avif)$">
    Header always set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>
</IfModule>
